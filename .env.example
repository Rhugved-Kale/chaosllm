# The proxy itself needs no secrets: it forwards whatever Authorization
# header the calling SDK sends and holds no provider key of its own.
#
# The demo app (demo/) is different: it IS the caller, so it needs its own
# provider key. Pick one provider and set its key; LLM_PROVIDER selects
# which one demo/ actually uses (default: openai). Only the selected
# provider's key is required; the other can stay unset.
LLM_PROVIDER=openai

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: switch the demo app's naive vs resilient LLM-call path
# (DESIGN.md 4.6). Defaults to false.
RESILIENT=false

# Optional: hard daily spend cap enforced in the proxy (DESIGN.md 5). Unset
# or empty means no cap. Once the cap is hit, /openai/* and /anthropic/*
# return 402 until the next UTC day; passthrough routes are never budgeted.
BUDGET_DAILY_USD=

# Optional: restrict the proxy's control API CORS to one origin (the
# deployed dashboard's URL). Unset means allow any origin, which is fine
# for local dev.
DASHBOARD_ORIGIN=
